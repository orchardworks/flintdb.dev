---
const benchmarks = [
  { op: "Bulk Insert (50K)", flint: 162, sqlite: 64, unit: "ms" },
  { op: "Get by ID", flint: 2.9, sqlite: 2.5, unit: "\u00b5s" },
  { op: "Eq Filter (indexed)", flint: 0.9, sqlite: 0.7, unit: "ms" },
  { op: "GroupBy avg", flint: 9.4, sqlite: 6.3, unit: "ms" },
  { op: "Range+Sort+Limit", flint: 0.26, sqlite: 0.02, unit: "ms" },
  { op: "Cold Open", flint: 15, sqlite: 0.6, unit: "ms" },
];

const rowH = 56;
const barH = 18;
const gap = 8;
const labelW = 180;
const valueW = 70;
const chartW = 700;
const barArea = chartW - labelW - valueW;
const headerH = 20;
const svgH = headerH + benchmarks.length * rowH + 10;
---

<section id="benchmarks" class="py-24 px-6 bg-surface-900">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-white text-center sm:text-4xl">
      Performance
    </h2>
    <p class="mt-3 text-center text-surface-400 text-sm">
      Benchmarked on Apple M1, 50,000 documents
    </p>

    <div class="mt-14">
      <svg
        viewBox={`0 0 ${chartW} ${svgH}`}
        width="100%"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Benchmark comparison chart: FlintDB vs SQLite"
      >
        {/* Legend */}
        <rect x={chartW - 240} y="0" width="12" height="12" rx="2" fill="#f59e0b" />
        <text x={chartW - 224} y="10" fill="#e4e4e7" font-size="11" font-family="ui-monospace, monospace">FlintDB</text>
        <rect x={chartW - 140} y="0" width="12" height="12" rx="2" fill="#3b82f6" />
        <text x={chartW - 124} y="10" fill="#e4e4e7" font-size="11" font-family="ui-monospace, monospace">SQLite</text>

        {benchmarks.map((b, i) => {
          const y = headerH + i * rowH;
          const max = Math.max(b.flint, b.sqlite);
          const flintW = Math.max((b.flint / max) * barArea, 4);
          const sqliteW = Math.max((b.sqlite / max) * barArea, 4);
          const barX = labelW;
          return (
            <g>
              {/* Operation label */}
              <text
                x="0"
                y={y + rowH / 2 - 2}
                fill="#e4e4e7"
                font-size="12"
                font-family="ui-sans-serif, system-ui, sans-serif"
                dominant-baseline="middle"
              >
                {b.op}
              </text>

              {/* FlintDB bar */}
              <rect
                x={barX}
                y={y + (rowH / 2 - barH - gap / 2)}
                width={flintW}
                height={barH}
                rx="4"
                fill="#f59e0b"
                opacity="0.9"
              />
              <text
                x={barX + flintW + 6}
                y={y + (rowH / 2 - gap / 2)}
                fill="#fbbf24"
                font-size="11"
                font-family="ui-monospace, monospace"
                dominant-baseline="middle"
              >
                {b.flint}{b.unit}
              </text>

              {/* SQLite bar */}
              <rect
                x={barX}
                y={y + (rowH / 2 + gap / 2)}
                width={sqliteW}
                height={barH}
                rx="4"
                fill="#3b82f6"
                opacity="0.9"
              />
              <text
                x={barX + sqliteW + 6}
                y={y + (rowH / 2 + gap / 2 + barH)}
                fill="#60a5fa"
                font-size="11"
                font-family="ui-monospace, monospace"
                dominant-baseline="middle"
              >
                {b.sqlite}{b.unit}
              </text>
            </g>
          );
        })}
      </svg>
    </div>

    <p class="mt-10 text-center text-surface-400 text-sm leading-relaxed max-w-2xl mx-auto">
      FlintDB trades raw speed for built-in analytics &mdash; stddev, EMA, MACD, RSI, Bollinger Bands computed inside the engine without external libraries.
    </p>
  </div>
</section>
