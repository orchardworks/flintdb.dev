---
const ossFeatures = [
  "Collections, Indexes, Views, Aliases",
  "Filter, Sort, GroupBy, Window",
  "avg, sum, stddev, percentile, ema, correlation",
  "Vector Search (Cosine, L2)",
];

const proFeatures = [
  "Financial Indicators (MACD, RSI, Bollinger, Ichimoku, VWAP)",
  "Statistical Analysis (t-test, ANOVA, Chi-square, K-means)",
  "Seasonal Decompose, Anomaly Detection",
  "Linear Forecast",
];
---

<section id="pricing" class="py-24 px-6 bg-surface-900">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-white text-center sm:text-4xl">
      Simple pricing
    </h2>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
      {/* OSS Card */}
      <div class="rounded-xl border border-surface-600 bg-surface-800 p-8 flex flex-col">
        <div class="flex items-center gap-3 mb-6">
          <h3 class="text-xl font-bold text-white">Core</h3>
          <span class="rounded-full bg-surface-700 px-3 py-0.5 text-xs font-semibold text-zinc-300">
            Free
          </span>
        </div>

        <ul class="space-y-3 flex-1">
          {ossFeatures.map((f) => (
            <li class="flex items-start gap-2 text-sm text-zinc-300">
              <svg class="w-5 h-5 shrink-0 text-flint-500 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <a
          href="https://docs.flintdb.dev"
          class="mt-8 inline-flex items-center justify-center rounded-lg border border-surface-600 bg-surface-700 px-5 py-3 text-sm font-medium text-zinc-200 transition hover:border-flint-500 hover:text-white"
        >
          Get Started
        </a>
      </div>

      {/* Pro Card */}
      <div class="relative rounded-xl border border-flint-500/40 bg-surface-800 p-8 flex flex-col shadow-[0_0_40px_-12px_rgba(245,158,11,0.15)]">
        <div class="flex items-center gap-3 mb-1">
          <h3 class="text-xl font-bold text-white">Pro</h3>
          <span class="rounded-full bg-flint-500/15 px-3 py-0.5 text-xs font-semibold text-flint-400">
            $99/yr
          </span>
        </div>
        <p class="text-xs text-surface-400 mb-6">per module</p>

        <p class="text-sm text-zinc-400 mb-4">Everything in Core, plus:</p>

        <ul class="space-y-3 flex-1">
          {proFeatures.map((f) => (
            <li class="flex items-start gap-2 text-sm text-zinc-300">
              <svg class="w-5 h-5 shrink-0 text-flint-500 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <a
          href="https://docs.flintdb.dev/pro/"
          class="mt-8 inline-flex items-center justify-center rounded-lg bg-flint-500 px-5 py-3 text-sm font-bold text-surface-900 transition hover:bg-flint-400"
        >
          Get Pro
        </a>
      </div>
    </div>
  </div>
</section>
