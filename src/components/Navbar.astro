---
---

<nav class="fixed top-0 z-50 w-full border-b border-surface-700/50 bg-surface-900/70 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo + Wordmark -->
    <a href="/" class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="h-7 w-7" aria-hidden="true">
        <path fill-rule="evenodd" d="M81 36 64 0 47 36l-1 2-9-10a6 6 0 0 0-9 9l10 10h-2L0 64l36 17h2L28 91a6 6 0 1 0 9 9l9-10 1 2 17 36 17-36v-2l9 10a6 6 0 1 0 9-9l-9-9 2-1 36-17-36-17-2-1 9-9a6 6 0 1 0-9-9l-9 10v-2Zm-17 2-2 5c-4 8-11 15-19 19l-5 2 5 2c8 4 15 11 19 19l2 5 2-5c4-8 11-15 19-19l5-2-5-2c-8-4-15-11-19-19l-2-5Z" clip-rule="evenodd" fill="#f59e0b" />
        <path d="M118 19a6 6 0 0 0-9-9l-3 3a6 6 0 1 0 9 9l3-3Zm-96 4c-2 2-6 2-9 0l-3-3a6 6 0 1 1 9-9l3 3c3 2 3 6 0 9Zm0 82c-2-2-6-2-9 0l-3 3a6 6 0 1 0 9 9l3-3c3-2 3-6 0-9Zm96 4a6 6 0 0 1-9 9l-3-3a6 6 0 1 1 9-9l3 3Z" fill="#f59e0b" />
      </svg>
      <span class="text-lg font-bold text-white">FlintDB</span>
    </a>

    <!-- Desktop center nav -->
    <div class="hidden items-center gap-8 md:flex">
      <a href="#features" class="text-sm text-zinc-400 transition-colors hover:text-flint-400">Features</a>
      <a href="#pricing" class="text-sm text-zinc-400 transition-colors hover:text-flint-400">Pricing</a>
    </div>

    <!-- Desktop right -->
    <div class="hidden items-center gap-5 md:flex">
      <a
        href="https://github.com/orchardworks/flintdb"
        target="_blank"
        rel="noopener noreferrer"
        class="text-zinc-400 transition-colors hover:text-white"
        aria-label="GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
        </svg>
      </a>
      <a
        href="https://docs.flintdb.dev"
        class="rounded-lg bg-flint-500/10 px-4 py-1.5 text-sm font-medium text-flint-400 transition-colors hover:bg-flint-500/20"
      >
        Docs
      </a>
    </div>

    <!-- Mobile hamburger (no-JS details/summary) -->
    <details class="group md:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-center text-zinc-400 hover:text-white" aria-label="Toggle menu">
        <!-- Hamburger icon (shown when closed) -->
        <svg class="h-6 w-6 group-open:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon (shown when open) -->
        <svg class="hidden h-6 w-6 group-open:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </summary>
      <div class="absolute left-0 right-0 top-full border-b border-surface-700/50 bg-surface-900/95 px-6 pb-4 backdrop-blur-xl">
        <div class="flex flex-col gap-4 pt-4">
          <a href="#features" class="text-sm text-zinc-400 transition-colors hover:text-flint-400">Features</a>
              <a href="#pricing" class="text-sm text-zinc-400 transition-colors hover:text-flint-400">Pricing</a>
          <hr class="border-surface-700" />
          <a
            href="https://github.com/orchardworks/flintdb"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-zinc-400 transition-colors hover:text-white"
          >
            GitHub
          </a>
          <a
            href="https://docs.flintdb.dev"
            class="text-sm font-medium text-flint-400 transition-colors hover:text-flint-300"
          >
            Docs
          </a>
        </div>
      </div>
    </details>
  </div>
</nav>
