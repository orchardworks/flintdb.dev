---
const commands = [
  { label: "npm", cmd: "npm install flintdb", id: "cta-npm" },
  { label: "pip", cmd: "pip install flintdb", id: "cta-pip" },
];

const links = [
  { text: "GitHub", href: "https://github.com/orchardworks/flintdb" },
  { text: "Documentation", href: "https://docs.flintdb.dev" },
  { text: "Quick Start", href: "https://docs.flintdb.dev/quick-start/" },
];
---

<section class="relative py-24 px-6 border-t border-surface-700">
  {/* Subtle top gradient */}
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-flint-500/5 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Get started in seconds
    </h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
      {commands.map((c) => (
        <div class="group flex items-center gap-3 rounded-lg border border-surface-600 bg-surface-800 px-5 py-3 font-mono text-sm text-zinc-100">
          <span class="text-surface-400 text-xs font-sans font-medium uppercase tracking-wide shrink-0">
            {c.label}
          </span>
          <span class="text-zinc-500">$</span>
          <span id={c.id} class="select-all whitespace-nowrap">{c.cmd}</span>
          <button
            type="button"
            class="cta-copy-btn ml-auto shrink-0 cursor-pointer rounded p-1 text-zinc-400 transition hover:text-flint-400"
            data-target={c.id}
            data-fallback={c.cmd}
            aria-label={`Copy ${c.label} install command`}
          >
            {/* Clipboard icon */}
            <svg class="cta-icon-clip h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            {/* Check icon */}
            <svg class="cta-icon-check hidden h-4 w-4 text-green-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </button>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {links.map((l) => (
        <a
          href={l.href}
          class="inline-flex items-center rounded-full border border-surface-600 bg-surface-800 px-5 py-2.5 text-sm font-medium text-zinc-200 transition hover:border-flint-500 hover:text-white"
        >
          {l.text}
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".cta-copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const targetId = btn.dataset.target;
      const fallback = btn.dataset.fallback ?? "";
      const el = targetId ? document.getElementById(targetId) : null;
      const clip = btn.querySelector(".cta-icon-clip");
      const check = btn.querySelector(".cta-icon-check");

      try {
        await navigator.clipboard.writeText(el?.textContent ?? fallback);
        clip?.classList.add("hidden");
        check?.classList.remove("hidden");
        setTimeout(() => {
          clip?.classList.remove("hidden");
          check?.classList.add("hidden");
        }, 2000);
      } catch {
        if (el) {
          const range = document.createRange();
          range.selectNodeContents(el);
          window.getSelection()?.removeAllRanges();
          window.getSelection()?.addRange(range);
        }
      }
    });
  });
</script>
