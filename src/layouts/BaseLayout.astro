---
interface Props {
  title?: string;
}

const { title = "FlintDB" } = Astro.props;
const description =
  "JSON-native embedded database with built-in analytics and vector search. No daemon, no schema, no ETL.";
const ogTitle = "FlintDB - The local database that should have existed";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://flintdb.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="bg-surface-900 text-zinc-200 antialiased">
    <slot />
  </body>
</html>
